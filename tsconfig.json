{
  "compilerOptions": {
    "strict": true,
    "declaration": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declarationMap": false,
    "jsx": "react",
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"],
      "@@/*": [".dumi/tmp/*"],
      "dumi": ["."],
      "dumi/dist/*": ["src/*"]
    },
    "types": ["vitest/globals"]
  },
  "include": [
    "*.d.ts",
    ".dumi/theme/**/*",
    ".dumi/app.tsx",
    ".dumirc.ts",
    "src/**/*"
  ]
}
